# Teamstandard .npmrc for infotek-teamet
# Kopier til frontend/.npmrc (eller der package.json ligger)

# Registre
@navikt:registry=https://npm.pkg.github.com/
registry=https://registry.npmjs.org/

# Sikkerhet: ikke kjør install-scripts (preinstall, postinstall, prepare osv.)
# Forhindrer supply chain-angrep via ondsinnede pakker
ignore-scripts=true

# Sikkerhet: ikke installer pakker nyere enn 7 dager (supply chain)
min-release-age=7

# Krev at engines-feltet i package.json overholdes
engine-strict=true
